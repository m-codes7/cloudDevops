{
  "name": "diarydevops",
  "version": "1.0.0",
  "description": "Primary question: How does a fully automated CI/CD pipeline affect deployment speed, failure rate, and recovery time vs manual deployment?",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "measure": "node scripts/measure_deployment.js",
    "test": "jest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "*",
    "@types/node": "^25.2.1",
    "@types/supertest": "*",
    "jest": "*",
    "supertest": "*",
    "ts-jest": "*",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"]
  }
}
